---
import Layout from "../layouts/Layout.astro";
import HeroSection from "../components/HeroSection.vue";
import FeaturesSection from "../components/FeaturesSection.vue";
import AboutSection from "../components/AboutSection.vue";
import PythaverseSection from "../components/PythaverseSection.vue";
import CtaSection from "../components/CtaSection.vue";
import LeanbotSummarySection from "../components/LeanbotSummarySection.vue";
import leanbotRobot from "../assets/images/Leanbot-nobg.png";
import leanbotRobot2 from "../assets/images/Leanbot-nobg-2.png";
---

<Layout>
	<HeroSection robotImageSrc={leanbotRobot.src} />
	<FeaturesSection />
	<AboutSection robotImageSrc={leanbotRobot2.src} />
	<LeanbotSummarySection client:load />
	<PythaverseSection />
	<CtaSection />
</Layout>
