---
import Layout from '../layouts/Layout.astro';
// @ts-ignore
import LombaDirectoryHero from '../components/lomba/LombaDirectoryHero.vue';
// @ts-ignore
import LombaList from '../components/lomba/LombaList.vue';
// @ts-ignore
import CtaSection from '../components/CtaSection.vue';

// SSR: fetch competitions from CMS API
export const prerender = false;

const CMS_API_URL = import.meta.env.CMS_API_URL;

let competitions: Record<string, unknown>[] = [];

if (CMS_API_URL) {
  try {
    const res = await fetch(`${CMS_API_URL}/v1/cms/public/articles?content_type=competition&status=published`);
    if (res.ok) {
      const json = await res.json();
      // The API returns { data: { data: [...] } } for paginated or { data: [...] } for plain
      const raw = json?.data?.data ?? json?.data ?? [];
      competitions = Array.isArray(raw) ? raw : [];
    }
  } catch (err) {
    console.error('Failed to fetch competitions:', err);
  }
}

const pageTitle = "Portal Informasi Lomba Robotika — Leanbot AiCI";
const pageDescription = "Temukan berbagai informasi kompetisi robotika, STEM, dan inovasi teknologi dari seluruh dunia yang sejalan dengan visi Leanbot AiCI.";
---

<Layout title={pageTitle} description={pageDescription}>
  <main class="w-full relative overflow-hidden bg-white">
    <!-- Hero Section Directory -->
    <LombaDirectoryHero client:load />
    
    <!-- Lomba External Grid List -->
    <LombaList competitions={competitions} client:visible />

    <!-- General CTA section -->
    <CtaSection 
      title="Siapkan Tim Anda Sekarang"
      subtitle="Jadikan Leanbot sebagai mitra inovasi Anda. Pelajari modul, ikuti kompetisi eksternal, dan raih prestasi di ajang nasional hingga internasional."
      btnText="Mulai Belajar"
      btnLink="/edukasi"
      client:visible 
    />
  </main>
</Layout>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
</style>
