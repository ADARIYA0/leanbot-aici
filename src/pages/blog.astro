import CtaSection from '../components/CtaSection.vue';
import BlogHero from '../components/BlogHero.vue';
import BlogGrid from '../components/BlogGrid.vue';
---

<Layout>
  <!-- Hero Banner Khusus Blog -->
  <BlogHero client:load />

  <!-- Grid Layout untuk Artikel Blog -->
  <BlogGrid client:load />

  <!-- Menggunakan Footer/CTA yang sama dengan halaman lain -->
  <CtaSection client:load />
</Layout>
