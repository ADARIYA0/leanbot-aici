---
import Layout from "../layouts/Layout.astro";
import SpecHero from "../components/specifications/SpecHero.vue";
import SpecDynamicViewer from "../components/specifications/SpecDynamicViewer.vue";
import CtaSection from "../components/CtaSection.vue";

export const prerender = true;
---

<Layout>
  <!-- Hero Banner untuk Halaman Spesifikasi -->
  <SpecHero client:load />

  <!-- Dynamic Specification Viewer (Carousel, Visual Map, Specs, Accessories) -->
  <SpecDynamicViewer client:load />

  <!-- Reused CTA Section -->
  <CtaSection client:load />
</Layout>
